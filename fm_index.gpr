project FM_Index is
   for Source_Dirs use ("src");
   for Object_Dir use "obj";
   
   package Compiler is
      for Default_Switches ("Ada") use (
         "-g", 
         "-O2", 
         "-gnata",   -- Enable assertions
         "-gnatwa"   -- Enable all warnings
      );
   end Compiler;
   
   package Prove is
      for Proof_Switches ("Ada") use (
         "--level=1", 
         "--report=all"
      );
   end Prove;
end FM_Index;
